{
  "name": "powerbi-report-mcp",
  "version": "0.6.1",
  "description": "MCP server for building Power BI reports (PBIR format)",
  "main": "dist/index.js",
  "bin": {
    "powerbi-report-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc && node -e \"const fs=require('fs');const f='dist/index.js';const c=fs.readFileSync(f,'utf8');if(!c.startsWith('#!/'))fs.writeFileSync(f,'#!/usr/bin/env node\\n'+c);\"",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "usage": "node dist/usage-cli.js",
    "usage:watch": "node dist/usage-cli.js --watch",
    "usage:app": "node dist/usage-app.js",
    "usage:md": "node dist/usage-md.js",
    "audit": "node scripts/audit-skill-coverage.js",
    "audit:strict": "node scripts/audit-skill-coverage.js --strict",
    "test:wireframe": "node scripts/test-wireframe-validator.js",
    "test:binding": "node scripts/test-binding-validator.js",
    "test:all": "npm run build && npm run audit:strict && npm run test:wireframe && npm run test:binding",
    "hooks:install": "node scripts/install-hooks.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.x",
    "typescript": "^5.x",
    "ts-node": "^10.x"
  }
}
