{
  "name": "powerbi-report-mcp",
  "version": "0.9.5",
  "description": "MCP server for building Power BI reports (PBIR format)",
  "main": "dist/index.js",
  "bin": {
    "powerbi-report-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "schemas",
    "skills",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "prepare": "npm run build",
    "build": "tsc && node -e \"const fs=require('fs');const f='dist/index.js';const c=fs.readFileSync(f,'utf8');if(!c.startsWith('#!/'))fs.writeFileSync(f,'#!/usr/bin/env node\\n'+c);\"",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "audit": "node scripts/audit-skill-coverage.js",
    "audit:strict": "node scripts/audit-skill-coverage.js --strict",
    "test:wireframe": "node scripts/test-wireframe-validator.js",
    "test:binding": "node scripts/test-binding-validator.js",
    "test:measure-home-table": "node scripts/test-measure-home-table.js",
    "test:extract-title": "node scripts/test-extract-title.js",
    "test:layout": "node scripts/test-layout-validator.js",
    "test:grid": "node scripts/test-layout-grid.js",
    "test:slicer": "node scripts/test-slicer-defaults.js",
    "test:schema-docs": "node scripts/audit-skills-against-schema.js",
    "test:surface": "node scripts/test-tool-surface.js",
    "test:pagination": "node scripts/test-pagination.js",
    "test:set-report": "node scripts/test-set-report.js",
    "schema:check": "node scripts/refresh-theme-schema.js --check",
    "schema:refresh": "node scripts/refresh-theme-schema.js",
    "test:all": "npm run build && npm run audit:strict && npm run test:wireframe && npm run test:binding && npm run test:measure-home-table && npm run test:extract-title && npm run test:layout && npm run test:grid && npm run test:slicer && npm run test:schema-docs && npm run test:surface && npm run test:pagination && npm run test:set-report",
    "hooks:install": "node scripts/install-hooks.js",
    "plugin:build": "node scripts/build-plugin.js",
    "eval:install": "pip install -r evals/requirements.txt",
    "eval": "python evals/run.py -t stdio -c node -a dist/index.js -e PBIR_REPORT_PATH=evals/fixtures/sample.Report -o evals/last-report.md evals/questions.xml",
    "measure:session": "node scripts/measure-session-cost.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.x",
    "typescript": "^5.x",
    "ts-node": "^10.x"
  }
}
